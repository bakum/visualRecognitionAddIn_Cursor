{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "windows-x64",
      "inherits": "windows-base",
      "displayName": "Windows x64",
      "description": "MSVC, платформа x64. PDF: MuPDF при сборке с vcpkg, иначе автозагрузка PDFium.",
      "architecture": "x64"
    },
    {
      "name": "windows-x86",
      "inherits": "windows-base",
      "displayName": "Windows Win32",
      "description": "MSVC Win32. PDF: MuPDF при vcpkg, иначе PDFium.",
      "architecture": "Win32"
    },
    {
      "name": "win32-release",
      "inherits": "windows-base",
      "displayName": "Windows x86 Release (скрипты)",
      "description": "Каталог сборки build/win32-release — как в barcodeAddIn_Cursor/scripts.",
      "architecture": "Win32"
    },
    {
      "name": "x64-release",
      "inherits": "windows-base",
      "displayName": "Windows x64 Release (скрипты)",
      "description": "Каталог сборки build/x64-release.",
      "architecture": "x64"
    },
    {
      "name": "windows-x64-vcpkg",
      "inherits": "windows-x64",
      "displayName": "Windows x64 (vcpkg / MuPDF)",
      "description": "Тот же x64, но с toolchain vcpkg (VCPKG_ROOT) — при установленном libmupdf будет MuPDF.",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "x64 Debug",
      "configurePreset": "windows-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-release",
      "displayName": "x64 Release",
      "configurePreset": "windows-x64",
      "configuration": "Release"
    },
    {
      "name": "windows-x86-debug",
      "displayName": "Win32 Debug",
      "configurePreset": "windows-x86",
      "configuration": "Debug"
    },
    {
      "name": "windows-x86-release",
      "displayName": "Win32 Release",
      "configurePreset": "windows-x86",
      "configuration": "Release"
    },
    {
      "name": "win32-release",
      "displayName": "Win32 Release (build/win32-release)",
      "configurePreset": "win32-release",
      "configuration": "Release"
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release (build/x64-release)",
      "configurePreset": "x64-release",
      "configuration": "Release"
    }
  ]
}
