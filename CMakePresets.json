{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "win32-release",
      "inherits": "windows-base",
      "displayName": "Windows x86 Release (скрипты)",
      "description": "Каталог сборки build/win32-release — как в barcodeAddIn_Cursor/scripts.",
      "architecture": "Win32"
    },
    {
      "name": "x64-release",
      "inherits": "windows-base",
      "displayName": "Windows x64 Release (скрипты)",
      "description": "Каталог сборки build/x64-release.",
      "architecture": "x64"
    },
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "linux-release",
      "inherits": "linux-base",
      "displayName": "Linux x64 Release",
      "description": "Каталог сборки build/linux-release.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win32-release",
      "displayName": "Win32 Release (build/win32-release)",
      "configurePreset": "win32-release",
      "configuration": "Release"
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release (build/x64-release)",
      "configurePreset": "x64-release",
      "configuration": "Release"
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release (build/linux-release)",
      "configurePreset": "linux-release"
    }
  ]
}
